# VITE_GEMINI_API_KEY: Required for Gemini AI API calls (OCR functionality).
# Get your API key from: https://makersuite.google.com/app/apikey
# This is exposed to the browser, so use a restricted API key.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_APP_URL: The URL where this applet is hosted.
# Used for self-referential links and OAuth callbacks.
VITE_APP_URL="http://localhost:3000"
